{
  "_comment": "Provenance + refresh config for every plugin in the compendium marketplace. scripts/refresh.py reads this to re-vendor each plugin from its upstream GitHub source. kind: 'plugin' = upstream is itself a Claude plugin (copy its .claude-plugin + skills); 'skill-wrap' = upstream is a bare skills repo (keep our wrapper plugin.json, vendor the named skills); 'local' = authored in-house, no upstream, never auto-refreshed.",
  "marketplace": {
    "name": "compendium",
    "repo": "samhv-dev/compendium",
    "url": "https://github.com/samhv-dev/compendium"
  },
